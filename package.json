{
  "name": "web3agent-sdk",
  "version": "0.1.0",
  "description": "Deploy autonomous AI agents on Arbitrum with LangChain, isolated wallets, and ERC-8004 identity registration.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "setup": "npx tsx src/cli/setup.ts",
    "create-agent": "npx tsx src/cli/create-agent.ts",
    "deploy": "npx tsx src/cli/deploy.ts",
    "chat": "npx tsx src/cli/chat.ts",
    "test": "npx tsx src/cli/test-workflow.ts"
  },
  "keywords": [
    "arbitrum",
    "ai-agents",
    "web3",
    "langchain",
    "erc-8004",
    "defi",
    "autonomous-agents"
  ],
  "license": "Apache-2.0",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@blockbyvlog/agent0-sdk": "^1.5.6",
    "@clack/prompts": "^1.1.0",
    "@langchain/anthropic": "^0.3.0",
    "@langchain/core": "^0.3.0",
    "@langchain/langgraph": "^0.2.0",
    "@langchain/openai": "^0.6.17",
    "@openrouter/sdk": "*",
    "dotenv": "^16.4.0",
    "ethers": "^6.13.0",
    "qrcode-terminal": "^0.12.0",
    "viem": "^2.47.4",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/qrcode-terminal": "^0.12.2",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
