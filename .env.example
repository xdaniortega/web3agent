# =============================================================================
# web3agent-sdk Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env or agents/*/wallet.json to version control.
# =============================================================================

# --- AI Provider ---
# Your Anthropic API key for Claude
ANTHROPIC_API_KEY=

# --- Network ---
# One of: arbitrum-sepolia (default), arbitrum-one, robinhood-testnet
NETWORK=arbitrum-sepolia

# --- Alchemy RPC Keys ---
# Only the key for your active network is required.
ALCHEMY_ARBITRUM_SEPOLIA_KEY=
ALCHEMY_ARBITRUM_ONE_KEY=
ALCHEMY_ROBINHOOD_TESTNET_KEY=

# --- Master Wallet ---
# Private key of the master wallet used to fund new agent wallets.
# This wallet needs Sepolia ETH to pay for agent funding and ERC-8004 registration gas.
MASTER_PRIVATE_KEY=

# --- ERC-8004 Registration (Optional) ---
# If set, registration will use Pinata IPFS mode instead of HTTP mode.
# PINATA_JWT=
