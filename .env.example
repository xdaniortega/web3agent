# =============================================================================
# web3agent-sdk Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env or agents/*/wallet.json to version control.
# =============================================================================

# --- LLM Provider ---
# One of: openrouter (default), anthropic, openai
LLM_PROVIDER=openrouter
# Optional: override the default model for the chosen provider
# LLM_MODEL=

# API key for the selected provider (only one is required)
OPENROUTER_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# --- Network ---
# One of: arbitrum-sepolia (default), arbitrum-one, robinhood-testnet
NETWORK=arbitrum-sepolia

# --- RPC Endpoint ---
# Full RPC endpoint URL including API key (e.g. https://arb-sepolia.g.alchemy.com/v2/YOUR_API_KEY)
RPC_URL=

# --- Master Wallet ---
# Private key of the master wallet used to fund new agent wallets.
# This wallet needs Sepolia ETH to pay for agent funding and ERC-8004 registration gas.
MASTER_PRIVATE_KEY=

# --- ERC-8004 Registration (Optional) ---
# If set, registration will use Pinata IPFS mode instead of HTTP mode.
# PINATA_JWT=
